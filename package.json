{
  "name": "penceai",
  "version": "0.1.0",
  "description": "PençeAI — Self-hosted, local-first AI agent platform",
  "type": "module",
  "license": "MIT",
  "main": "dist/gateway/index.js",
  "scripts": {
  "dev": "concurrently -k --raw -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
  "dev:frontend": "wait-on --timeout 60000 http://localhost:3001/api/health && cd src/web/react-app && npm run dev",
  "dev:backend": "chcp 65001 >nul 2>&1 & tsx watch src/gateway/index.ts",
  "dev:backend-only": "chcp 65001 >nul 2>&1 & tsx watch src/gateway/index.ts",
  "build": "tsc && cd src/web/react-app && npm run build",
  "start": "node dist/gateway/index.js",
  "cli": "tsx src/cli/index.ts",
  "maintenance": "tsx src/cli/maintenance.ts",
  "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@azure/core-sse": "^2.3.0",
    "@mozilla/readability": "^0.6.0",
    "@types/validator": "^13.15.10",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "chrono-node": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "gpt-tokenizer": "^3.4.0",
    "linkedom": "^0.18.12",
    "openai": "^4.77.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "turndown": "^7.2.2",
    "uuid": "^11.1.0",
    "validator": "^13.15.26",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
