{
  "name": "penceai",
  "version": "0.1.0",
  "description": "PençeAI — Self-hosted, local-first AI agent platform",
  "type": "module",
  "license": "MIT",
  "main": "dist/gateway/index.js",
  "scripts": {
    "dev": "concurrently -k --raw -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "wait-on --timeout 120000 --interval 2000 http://localhost:3001/api/health && cd src/web/react-app && npm run dev",
    "dev:backend": "chcp 65001 >nul 2>&1 & tsx watch src/gateway/index.ts",
    "dev:backend-only": "chcp 65001 >nul 2>&1 & tsx watch src/gateway/index.ts",
    "build": "tsc && npx shx cp src/agent/mcp/marketplace-catalog.json dist/agent/mcp/ && cd src/web/react-app && npm run build",
    "start": "node dist/gateway/index.js",
    "cli": "tsx src/cli/index.ts",
    "maintenance": "tsx src/cli/maintenance.ts",
    "test": "jest --config jest.config.js",
    "test:frontend": "jest --config jest.config.js --testPathPattern='tests/frontend'",
    "test:frontend:watch": "jest --config jest.config.js --testPathPattern='tests/frontend' --watch",
    "test:frontend:coverage": "jest --config jest.config.js --testPathPattern='tests/frontend' --coverage",
    "test:ui": "jest --config jest.config.js --testPathPattern='tests/frontend/ui'",
    "test:integration": "jest --config jest.config.js --testPathPattern='tests/frontend/integration'",
    "test:e2e:legacy": "jest --config jest.config.js --testPathPattern='tests/frontend/e2e'",
    "test:mcp:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:mcp:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:mcp:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:mcp:e2e:report": "npx playwright show-report tests/e2e/reports",
    "test:mcp:e2e:debug": "playwright test --config=tests/e2e/playwright.config.ts --debug",
    "graphrag:status": "tsx src/cli/maintenance.ts graphrag-status",
    "graphrag:advance": "tsx src/cli/maintenance.ts graphrag-advance",
    "graphrag:set-phase": "tsx src/cli/maintenance.ts graphrag-set-phase",
    "graphrag:readiness": "tsx src/cli/maintenance.ts graphrag-readiness",
    "graphrag:go-full": "tsx src/cli/maintenance.ts graphrag-go-full",
    "graphrag:emergency-rollback": "tsx src/cli/maintenance.ts graphrag-emergency-rollback",
    "graphrag:metrics": "tsx src/cli/maintenance.ts graphrag-metrics",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "setup:unix": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@azure/core-sse": "^2.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@types/validator": "^13.15.10",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "chrono-node": "^2.9.0",
    "cors": "^2.8.5",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "glob": "^13.0.6",
    "gpt-tokenizer": "^3.4.0",
    "linkedom": "^0.18.12",
    "openai": "^4.77.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "turndown": "^7.2.2",
    "uuid": "^11.1.0",
    "validator": "^13.15.26",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@eslint/js": "^9.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.40.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
