# PençeAI public repo için güvenli örnek environment dosyası
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.

# --- Sunucu ---
PORT=3001
HOST=localhost

# --- Veritabanı ---
DB_PATH=./data/penceai.db

# --- LLM Providers ---
# En az bir provider anahtarını doldurun.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
VOYAGE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
ENABLE_OLLAMA_TOOLS=false
ENABLE_NVIDIA_TOOLS=false
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# --- Mesajlaşma Kanalları ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_CHANNELS=
WHATSAPP_ENABLED=false

# --- Güvenlik ---
ALLOW_SHELL_EXECUTION=false
FS_ROOT_DIR=
DASHBOARD_PASSWORD=
BRAVE_SEARCH_API_KEY=
SENSITIVE_PATHS=C:\\Windows,C:\\Program Files,C:\\Program Files (x86),C:\\Users\\<user>\\AppData,C:\\ProgramData,/etc,/usr,/var,/boot,/root

# --- Embedding (Semantik Arama) ---
# Provider seçenekleri: minimax, openai, voyage, none
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Uygulama Davranışı ---
SYSTEM_PROMPT=
AUTONOMOUS_STEP_LIMIT=5
MEMORY_DECAY_THRESHOLD=30
SEMANTIC_SEARCH_THRESHOLD=0.7
LOG_LEVEL=info
DEFAULT_USER_NAME=

# --- MCP (Model Context Protocol) ---
# MCP'yi etkinleştirmek için 'true' yapın
ENABLE_MCP=true

# MCP Server'ları (JSON array formatında)
# Örnek: [{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/izinli/dizin"]}]
MCP_SERVERS=

# Varsayılan timeout (milisaniye)
MCP_TIMEOUT=30000

# Maksimum paralel araç çağrısı
MCP_MAX_CONCURRENT=5

# MCP logging
MCP_LOGGING=true

# --- Observability (Langfuse) ---
# LLM çağrıları, agent loop ve memory retrieval tracing için
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Self-hosted Langfuse için:
# LANGFUSE_BASE_URL=http://localhost:3000
