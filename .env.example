# PençeAI public repo için güvenli örnek environment dosyası
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.

# --- Sunucu ---
PORT=3001
HOST=0.0.0.0

# --- Veritabanı ---
DB_PATH=./data/penceai.db

# --- LLM Providers ---
# En az bir provider anahtarını doldurun.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
VOYAGE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
ENABLE_OLLAMA_TOOLS=false
ENABLE_NVIDIA_TOOLS=false
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# --- Mesajlaşma Kanalları ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
WHATSAPP_ENABLED=false

# --- Güvenlik ---
ALLOW_SHELL_EXECUTION=false
# Shell komut zaman aşımı (milisaniye, varsayılan: 30000)
SHELL_TIMEOUT=30000
FS_ROOT_DIR=
DASHBOARD_PASSWORD=
BRAVE_SEARCH_API_KEY=
JINA_READER_API_KEY=
SENSITIVE_PATHS=C:\\Windows,C:\\Program Files,C:\\Program Files (x86),C:\\Users\\<user>\\AppData,C:\\ProgramData,/etc,/usr,/var,/boot,/root

# --- Embedding (Semantik Arama) ---
# Provider seçenekleri: minimax, openai, voyage, none
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Uygulama Davranışı ---
SYSTEM_PROMPT=
AUTONOMOUS_STEP_LIMIT=5
MEMORY_DECAY_THRESHOLD=30
SEMANTIC_SEARCH_THRESHOLD=0.7
LOG_LEVEL=info
DEFAULT_USER_NAME=
TEMPERATURE=0.7
MAX_TOKENS=4096

# --- MCP (Model Context Protocol) ---
# MCP'yi etkinleştirmek için 'true' yapın
ENABLE_MCP=true

# MCP Server'ları (JSON array formatında)
# Örnek: [{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/izinli/dizin"]}]
MCP_SERVERS=

# Varsayılan timeout (milisaniye)
MCP_TIMEOUT=30000

# Maksimum paralel araç çağrısı
MCP_MAX_CONCURRENT=5

# MCP logging
MCP_LOGGING=true

# --- Hook Execution Engine ---
# Tool call lifecycle event'lerini yakalama, engelleme ve modification sistemi
ENABLE_HOOKS=true
# Security Monitor: Path traversal, secret pattern, destructive command tespiti
HOOK_SECURITY_MONITOR=true
# Output Sanitizer: API key/password masking
HOOK_OUTPUT_SANITIZER=true
# Console.log Detector: 'ask' = uyarı, 'approve' = izin ver, 'block' = engelle
HOOK_CONSOLE_LOG_DETECTOR=ask
# Observation Capture: Tool call'ları otomatik log olarak kaydet
HOOK_OBSERVATION_CAPTURE=true
# Dev Server Blocker: Dev server komutlarını uyar (npm run dev, yarn start, vb.)
HOOK_DEV_SERVER_BLOCKER=true
# Context Budget Guard: ~40 tool call'da compaction öner, ~60'da zorunlu kıl
HOOK_CONTEXT_BUDGET_GUARD=true
# Session Summary: Oturum sonunda metrik özeti kaydet
HOOK_SESSION_SUMMARY=true

# --- Context Compaction ---
# Uzun konuşmalarda token bütçesini aşarsa otomatik sıkıştırma
COMPACT_ENABLED=true
# Token eşiği (bu değeri aşarsa compaction tetiklenir)
COMPACT_TOKEN_THRESHOLD=100000
# Sıkıştırma sırasında korunacak son mesaj sayısı
COMPACT_PRESERVE_RECENT_MESSAGES=10
# Dosya eklerini koru (true/false)
COMPACT_PRESERVE_FILE_ATTACHMENTS=true
# Korunan dosya eki maksimum boyutu (byte)
COMPACT_MAX_FILE_ATTACHMENT_BYTES=51200

# --- LLM Prompt Cache ---
# SQLite üzerinde MD5(Prompt+Model) → Response önbellekleme
# Aynı soruya tekrar denk gelindiğinde API maliyeti $0 olur, yanıt süresi 10-20ms'ye düşer
LLM_CACHE_ENABLED=true
# Önbellek süresi (saat). Bu süreden eski kayıtlar silinir
LLM_CACHE_TTL_HOURS=24
# Maksimum önbellek kayıt sayısı (aşılırsa en eski kullanılmayanlar silinir)
LLM_CACHE_MAX_ENTRIES=1000

# --- GraphRAG Rollout ---
# GraphRAG FULL phase'e geçiş onayı için (sadece CLI kullanımı)
# Kullanım: GRAPHRAG_CONFIRM=yes npm run graphrag:go-full
# GRAPHRAG_CONFIRM=yes

# --- Agentic RAG ---
# LLM'in kendi retrieval stratejisini seçmesi, passage eleştirisi ve self-evaluation
# Varsayılan: açık (true). Kapamak için 'false' yapın.
AGENTIC_RAG_ENABLED=true
# Multi-hop retrieval: eksik bilgi varsa kaç kez tekrar aransın? (1-5)
AGENTIC_RAG_MAX_HOPS=3
# Retrieval kararı için minimum confidence eşiği (0-1). Altındaysa retrieval yapılmaz.
AGENTIC_RAG_DECISION_CONFIDENCE=0.5
# Passage kritik alaka düzeyi eşiği (0-1). Altındaki passage'lar elenir.
AGENTIC_RAG_CRITIQUE_RELEVANCE_FLOOR=0.5
# Passage kritik tamamlılık eşiği (0-1). Altındaki passage'lar elenir.
AGENTIC_RAG_CRITIQUE_COMPLETENESS_FLOOR=0.3
# Yanıt doğrulama destek eşiği (0-1). Altındaysa regenerasyon tetiklenir.
AGENTIC_RAG_VERIFICATION_SUPPORT_FLOOR=0.6
# Yanıt doğrulama yararlilik eşiği (1-5). Altındaysa regenerasyon tetiklenir.
AGENTIC_RAG_VERIFICATION_UTILITY_FLOOR=2
# Maksimum yanıt regenerasyon sayısı (0-3)
AGENTIC_RAG_MAX_REGENERATIONS=1

# --- Karpathy LLM Wiki ---
ENABLE_MEMORY_LINT=true
LINT_PASS_INTERVAL_HOURS=168
LINT_LLM_VALIDATION_ENABLED=true
LINT_DETERMINISTIC_THRESHOLD_JACCARD=0.8
LINT_MAX_LLM_PAIRS_PER_RUN=20
ENABLE_PROVENANCE_TRACKING=true
WIKI_EXPORT_DIR=./exports
WIKI_ADAPTIVE_THRESHOLD=100
