{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Marketplace Catalog",
  "description": "Schema for the MCP Marketplace catalog file containing available server definitions",
  "type": "object",
  "required": ["version", "servers"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Catalog version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "servers": {
      "type": "array",
      "description": "List of available MCP server definitions",
      "items": {
        "$ref": "#/definitions/serverEntry"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "definitions": {
    "serverEntry": {
      "type": "object",
      "description": "A single MCP server catalog entry",
      "required": [
        "name",
        "description",
        "version",
        "author",
        "tags",
        "command",
        "defaultArgs",
        "defaultEnv",
        "sourceUrl",
        "tools"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Server name (unique identifier)",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "description": {
          "type": "string",
          "description": "Server description",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "description": "Server version",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "author": {
          "type": "string",
          "description": "Author or publisher name",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "description": "Tags for search and categorization",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "icon": {
          "type": "string",
          "description": "Icon (emoji or URL, optional)"
        },
        "command": {
          "type": "string",
          "description": "Command to execute the server",
          "minLength": 1
        },
        "defaultArgs": {
          "type": "array",
          "description": "Default command arguments",
          "items": {
            "type": "string"
          }
        },
        "defaultEnv": {
          "type": "object",
          "description": "Default environment variables",
          "additionalProperties": {
            "type": "string"
          }
        },
        "sourceUrl": {
          "type": "string",
          "description": "Source URL (documentation, GitHub, etc.)",
          "format": "uri"
        },
        "npmPackage": {
          "type": "string",
          "description": "NPM package name (optional)"
        },
        "githubRepo": {
          "type": "string",
          "description": "GitHub repository (optional)"
        },
        "tools": {
          "type": "array",
          "description": "List of available tools",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "rating": {
          "type": "number",
          "description": "User rating (1-5, optional)",
          "minimum": 1,
          "maximum": 5
        },
        "installCount": {
          "type": "integer",
          "description": "Installation count (optional)",
          "minimum": 0
        }
      }
    }
  }
}
